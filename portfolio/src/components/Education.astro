---
interface Props {
  t: any;
}

const { t } = Astro.props;
---

<section class="section" id="education">
  <div class="container">
    <div class="section-header fade-in">
      <h2 class="section-title">
        <span class="section-title-accent">{t.education.title}</span>
      </h2>
      <p class="section-subtitle">{t.education.subtitle}</p>
    </div>

    <div class="education-cards">
      {t.education.items.map((item: any) => (
        <div class="education-card fade-in">
          <span class="education-period">{item.period}</span>
          <h3 class="education-degree">{item.degree}</h3>
          <p class="education-school">🏛️ {item.school}</p>
          <p class="education-description">{item.description}</p>
          <div class="timeline-highlights">
            {item.highlights.map((h: string) => (
              <span class="timeline-highlight">{h}</span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
